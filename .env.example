# Copy to .env and fill in a real bcrypt hash before running `make up`.
# .env is gitignored; .env.example is tracked.
#
# Generate a hash:
#   sudo apt install apache2-utils      # Debian/Ubuntu (for htpasswd)
#   htpasswd -nB admin
#
# Then paste the output below, DOUBLING every `$`. docker compose still
# runs variable interpolation on the substituted value, so `$2y` would
# otherwise be read as an (empty) variable reference. Example:
#   htpasswd:     admin:$2y$05$abcDEF...
#   in this file: admin:$$2y$$05$$abcDEF...

DASHBOARD_AUTH=admin:$$2y$$05$$REPLACE_WITH_YOUR_OWN_BCRYPT_HASH
